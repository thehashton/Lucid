{
  "name": "lucid-a11y",
  "version": "0.1.0",
  "description": "Automated accessibility auditing across full web projects.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "lucid": "./dist/cli.js"
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thehashton/Lucid.git"
  },
  "homepage": "https://github.com/thehashton/Lucid#readme",
  "bugs": {
    "url": "https://github.com/thehashton/Lucid/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "axe-core",
    "playwright",
    "audit",
    "wcag",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.7.2",
    "@octokit/rest": "^21.0.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.4.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "prettier": "^3.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5",
    "@types/node": "^22.10.1"
  }
}
